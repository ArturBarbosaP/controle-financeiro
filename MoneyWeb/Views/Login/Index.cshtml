@using MoneyWeb.Models.ViewModels
@using MoneyWeb.Helpers
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<div class="card text-start border-dark mb-3">
    <div class="card-body">
        <form asp-controller="Login" asp-action="Index" method="post">

            <div class="form-floating mb-3">
                <input type="text" asp-for="Usuario" class="form-control @Html.GetValidationCssClass(nameof(Model.Usuario))" id="txtUsuario" aria-describedby="nomeHelp" placeholder="" />
                <span asp-validation-for="Usuario" class="invalid-feedback"></span>
                <label for="txtUsuario">Usuário</label>
            </div>

            <div class="form-floating mb-3">
                <input type="password" asp-for="Senha" class="form-control @Html.GetValidationCssClass(nameof(Model.Senha))" id="txtSenha" aria-describedby="nomeHelp" placeholder="" />
                <span asp-validation-for="Senha" class="invalid-feedback"></span>
                <label for="txtSenha">Senha</label>
            </div>

            <div asp-validation-summary="All" class="is-invalid text-danger"></div>

            <button type="submit" class="btn btn-primary">Entrar</button>
        </form>
    </div>
</div>